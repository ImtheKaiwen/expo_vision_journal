{
  "expo": {
    "name": "VisionJournal",
    "slug": "VisionJournal",
    "version": "1.3.4",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "plugins": [
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ]
    ],
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#090909"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.imthekaiwen.VisionJournal",
      "buildNumber": "1.2.2",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSUserNotificationsUsageDescription": "VisionJournal günlük hatırlatıcıları için bildirim gönderir."
      }
    },
    "android": {
      "package": "com.imthekaiwen.VisionJournal",
      "versionCode": 4,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#090909"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "f9f98a93-f83d-474e-839c-bd74a551df5f"
      }
    }
  }
}